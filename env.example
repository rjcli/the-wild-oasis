# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Database credentials - CHANGE THESE IN PRODUCTION
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=wild_oasis

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# JWT Secrets - GENERATE SECURE RANDOM VALUES FOR PRODUCTION
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration - Update allowed origins as needed
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE_MB=5

# ─── UI ───────────────────────────────────────────────────────────────────────
UI_PORT=80
VITE_APP_TITLE=Wild Oasis
VITE_APP_VERSION=1.0.0

# These are baked into the Vite bundle at image build time.
# If your API is exposed on a custom domain/port, update both values.
VITE_API_ORIGIN=http://localhost:3000
VITE_API_URL=http://localhost:3000/api/v1
