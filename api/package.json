{
  "name": "the-wild-oasis_api",
  "private": true,
  "version": "1.0.0",
  "author": "Rashmi Raj",
  "description": "Wild Oasis Hotel Management REST API — Node.js + TypeScript + PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "db:seed:pg": "node scripts/seed-demo-pg.js",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx,ts,tsx --fix",
    "prettier-setup": "yarn add --save-dev prettier eslint-config-prettier eslint-plugin-prettier",
    "prettier": "prettier --check \"**/*.{js,jsx,json,html,css,ts,tsx,yml,yaml,md}\"",
    "prettier:write": "prettier --write \"**/*.{js,jsx,json,html,css,ts,tsx,yml,yaml,md}\" --ignore-unknown",
    "husky:prepare": "npx husky init"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,html,css,json,md,json}": [
      "npm run prettier:write"
    ]
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "husky": "^9.1.7",
    "jsonwebtoken": "^9.0.2",
    "lint-staged": "^16.4.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openapi-types": "^12.1.3",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "sharp": "^0.33.4",
    "swagger-ui-express": "^5.0.1",
    "vite-plugin-eslint": "^1.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.9",
    "@types/sharp": "^0.31.1",
    "@types/swagger-ui-express": "^4.1.8",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "prisma": "^5.15.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.57.0"
  }
}
