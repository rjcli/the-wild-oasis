# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/wild_oasis?schema=public"

# JWT
JWT_SECRET=your-very-long-random-secret-key-here-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=another-very-long-random-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# File uploads
MAX_FILE_SIZE_MB=5
UPLOADS_DIR=public/uploads
