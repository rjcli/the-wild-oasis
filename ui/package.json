{
  "name": "the-wild-oasis_ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prettier-setup": "yarn add --save-dev prettier eslint-config-prettier eslint-plugin-prettier",
    "prettier": "prettier --check \"**/*.{js,jsx,json,html,css,ts,tsx,yml,yaml,md}\"",
    "prettier:write": "prettier --write \"**/*.{js,jsx,json,html,css,ts,tsx,yml,yaml,md}\" --ignore-unknown",
    "husky:prepare": "npx husky init"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,html,css,json,md,json}": [
      "npm run prettier:write"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.18",
    "@tanstack/react-query-devtools": "^5.51.16",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "identity-obj-proxy": "^3.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.2",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.2.1",
    "react-router-dom": "^6.25.1",
    "recharts": "^3.8.0",
    "styled-components": "^6.1.12",
    "ts-jest": "^29.4.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "husky": "^9.1.5",
    "jest": "^30.3.0",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "typescript": "^5.3.3",
    "vite": "^5.3.1",
    "vite-plugin-eslint": "^1.8.1"
  }
}
